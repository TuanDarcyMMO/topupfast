# ============================================================
# TopUpFast Bot - Environment Variables
# ============================================================

# ---- Discord ----
DISCORD_TOKEN=your_discord_bot_token_here
# Guild ID để sync slash commands nhanh hơn (để trống = sync global, chậm hơn ~1h)
DISCORD_GUILD_ID=your_guild_id_here

# ---- SePay (Bank VN) ----
# API Token lấy tại: https://my.sepay.vn -> Cài đặt -> API Token
SEPAY_API_TOKEN=your_sepay_api_token_here
# Mã ngân hàng (xem danh sách tại https://sepay.vn/list-bank.html)
SEPAY_BANK_CODE=BIDV
# Số tài khoản ngân hàng nhận tiền
SEPAY_ACCOUNT_NUMBER=your_bank_account_number
# Tên chủ tài khoản (VIẾT HOA, không dấu)
SEPAY_ACCOUNT_NAME=NGUYEN VAN A

# ---- CoinRemitter ----
# Lấy API Key tại: https://coinremitter.com -> Settings -> API
COINREMITTER_API_KEY=your_coinremitter_api_key
COINREMITTER_PASSWORD=your_coinremitter_password
# Wallet ID cho từng coin (để trống nếu không dùng)
COINREMITTER_WALLET_LTC=your_ltc_wallet_id
COINREMITTER_WALLET_BTC=your_btc_wallet_id
COINREMITTER_WALLET_ETH=your_eth_wallet_id
COINREMITTER_WALLET_USDT=your_usdt_wallet_id

# ---- Webhook Server ----
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
# URL công khai của server (bot sẽ gửi URL này cho CoinRemitter)
# Ví dụ: https://yourserver.com hoặc dùng ngrok khi test
WEBHOOK_BASE_URL=http://160.191.245.231:8080

# ---- Cài đặt chung ----
DATABASE_PATH=topupfast.db
# Tỉ giá VND/USD (dùng để quy đổi khi nạp qua bank)
EXCHANGE_RATE=26000

# ---- OpenAI (AI chatbot tự động trong ticket Discord) ----
# Lấy key tại: https://platform.openai.com/api-keys
# Để trống = tắt AI bot, chỉ relay thủ công
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Số tiền nạp tối thiểu
MIN_DEPOSIT_VND=10000
MIN_DEPOSIT_USD=1.0
# Thời gian hết hạn giao dịch (phút)
PAYMENT_EXPIRY_MINUTES=30
